{
  "name": "mcp",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/http.js",
    "start:stdio": "node dist/src/index.js",
    "dev": "node --watch src/http.ts",
    "typecheck": "tsc --noEmit",
    "dev:ins": "DANGEROUSLY_OMIT_AUTH=true npx @modelcontextprotocol/inspector npm run start:stdio"
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "^0.22.0",
    "@types/node": "^25.9.0",
    "typescript": "^5"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "overrides": {
    "shell-quote": "1.8.4"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  }
}
