{
  "name": "serphouse-mcp",
  "version": "1.0.0",
  "description": "SERPHouse MCP Server — connect AI assistants to live SERP data, Google verticals, and SEO intelligence.",
  "mcpName": "io.github.SERPHouse/serphouse-mcp",
  "type": "module",
  "bin": {
    "serphouse-mcp": "dist/src/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/http.js",
    "start:stdio": "node dist/src/index.js",
    "dev": "node --watch src/http.ts",
    "typecheck": "tsc --noEmit",
    "dev:ins": "DANGEROUSLY_OMIT_AUTH=true npx @modelcontextprotocol/inspector npm run start:stdio",
     "format": "npx prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\""
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "^0.22.0",
    "@types/node": "^25.9.0",
    "typescript": "^5"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "overrides": {
    "shell-quote": "1.8.4"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/serphouse/serphouse-mcp.git"
  },
  "publisher": "SERPHouse",
  "keywords": [
    "serp api",
    "scraping",
    "serphouse mcp",
    "serp scraping",
    "serp data",
    "serp intelligence",
    "serp tasks",
    "serp results",
    "serp",
    "mcp server",
    "google serp api",
    "yahoo serp api",
    "sdk",
    "serphouse",
    "Search",
    "Result",
    "scrape"
  ]
}
